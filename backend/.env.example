# Copy this file to ".env" and fill in your Supabase project values.
# Find these in Supabase: Project Settings -> API
#
# If you leave these BLANK, the backend runs with built-in sample data
# (in-memory) so you can develop the UI immediately. Add them when you're
# ready to persist data for real.

SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Port the API listens on (frontend expects 4000 by default)
PORT=4000
